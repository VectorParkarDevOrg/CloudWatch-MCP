# CloudWatch MCP Server — environment variables
# Copy to .env and fill in your values

# AWS credentials (or attach an IAM role to the EC2 host — no creds needed then)
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=us-east-1

# Port to listen on (default: 8091)
PORT=8091

# Optional Bearer token — if set, VERA must send this as Authorization: Bearer <token>
# Set the same value in VERA Settings → Integrations → AWS CloudWatch → Bearer Token
BEARER_TOKEN=
